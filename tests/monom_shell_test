#!/usr/bin/env bash
# shUnit2 e2e tests for: src/monom shell bindings
# Run directly: bash tests/monom_shell_test

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# MONOMD is used by oneTimeSetUp() in helpers to build the binary before tests run.
# shellcheck disable=SC2034
MONOMD="$REPO_ROOT/bin/mnmd"
SHUNIT2="$REPO_ROOT/dependencies/shunit2"
SRC_MONOM="$REPO_ROOT/src/monom"
SRC_MONOM_BASH="$REPO_ROOT/src/monom.bash"
SRC_MONOM_ZSH="$REPO_ROOT/src/monom.zsh"

# shellcheck disable=SC1091
. "$SCRIPT_DIR/helpers"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# make_complete_project — creates a temp project whose `monom` config prints
# two slash-delimited paths when called with `complete`. Returns project dir.
make_complete_project() {
  local d
  d=$(mktemp -d)
  d=$(cd "$d" && pwd -P)
  cat > "$d/monom" <<'EOF'
#!/bin/sh
case "$1" in
  complete) printf 'cmd1\ncmd2\n' ;;
esac
EOF
  chmod +x "$d/monom"
  printf '%s' "$d"
}

# ---------------------------------------------------------------------------
# _MONOM_LIB_ROOT is set on source
# ---------------------------------------------------------------------------

test_monom_lib_root_is_set() {
  local output
  output=$(bash --norc --noprofile -c "
    source '$SRC_MONOM'
    echo \"\$_MONOM_LIB_ROOT\"
  " 2>/dev/null)
  assertEquals "_MONOM_LIB_ROOT should be the src/ directory" \
    "$REPO_ROOT/src" "$output"
}

# ---------------------------------------------------------------------------
# _setup_monom uses pre-set _MONOM_PROJECT_ROOT
# ---------------------------------------------------------------------------

test_setup_monom_uses_existing_project_root() {
  local proj
  proj=$(make_complete_project)

  local output
  output=$(bash --norc --noprofile -c "
    PATH='$REPO_ROOT/bin:$PATH'
    source '$SRC_MONOM'
    _MONOM_PROJECT_ROOT='$proj'
    _setup_monom
    echo \"\$_MONOM_USER_CONFIG\"
  " 2>/dev/null)

  assertEquals "_MONOM_USER_CONFIG should be set from pre-set root" \
    "$proj/monom" "$output"

  rm -rf "$proj"
}

# ---------------------------------------------------------------------------
# _setup_monom discovers root from PWD
# ---------------------------------------------------------------------------

test_setup_monom_discovers_root() {
  local proj
  proj=$(make_complete_project)

  local output
  output=$(bash --norc --noprofile -c "
    PATH='$REPO_ROOT/bin:$PATH'
    unset _MONOM_PROJECT_ROOT
    cd '$proj'
    source '$SRC_MONOM'
    _setup_monom
    echo \"\$_MONOM_PROJECT_ROOT\"
    echo \"\$_MONOM_USER_CONFIG\"
  " 2>/dev/null)

  local root config
  root=$(printf '%s' "$output" | head -1)
  config=$(printf '%s' "$output" | tail -1)

  assertEquals "_MONOM_PROJECT_ROOT should be discovered" "$proj" "$root"
  assertEquals "_MONOM_USER_CONFIG should be set"         "$proj/monom" "$config"

  rm -rf "$proj"
}

# ---------------------------------------------------------------------------
# _setup_monom returns non-zero outside any project
# ---------------------------------------------------------------------------

test_setup_monom_fails_outside_project() {
  local exit_code
  exit_code=$(bash --norc --noprofile -c "
    PATH='$REPO_ROOT/bin:$PATH'
    unset _MONOM_PROJECT_ROOT
    cd /tmp
    source '$SRC_MONOM'
    _setup_monom
    echo \$?
  " 2>/dev/null)

  assertNotEquals "_setup_monom should fail outside a project" 0 "$exit_code"
}

# ---------------------------------------------------------------------------
# _monom_cfg forwards args to _MONOM_USER_CONFIG
# ---------------------------------------------------------------------------

test_monom_cfg_forwards_args() {
  local proj
  proj=$(make_complete_project)

  local output
  output=$(bash --norc --noprofile -c "
    PATH='$REPO_ROOT/bin:$PATH'
    _MONOM_PROJECT_ROOT='$proj'
    source '$SRC_MONOM'
    _setup_monom
    _monom_cfg complete
  " 2>/dev/null)

  assertEquals "_monom_cfg complete should return project's paths" \
    "$(printf 'cmd1\ncmd2')" "$output"

  rm -rf "$proj"
}

# ---------------------------------------------------------------------------
# _monom_completion is defined and registered in bash
# ---------------------------------------------------------------------------

test_monom_completion_defined_in_bash() {
  local fn_exists hook_registered
  fn_exists=$(bash --norc --noprofile -c "
    source '$SRC_MONOM_BASH'
    declare -f _monom_completion > /dev/null 2>&1 && echo yes || echo no
  " 2>/dev/null)

  hook_registered=$(bash --norc --noprofile -c "
    source '$SRC_MONOM_BASH'
    complete -p monom 2>/dev/null
  " 2>/dev/null)

  assertEquals "_monom_completion function should exist" "yes" "$fn_exists"
  # complete -p monom prints something like: complete -F _monom_completion monom
  if ! printf '%s' "$hook_registered" | grep -qF -- "-F _monom_completion"; then
    fail "complete -p monom should show -F _monom_completion; got: $hook_registered"
  fi
}

# ---------------------------------------------------------------------------
# _monom function is defined after sourcing monom.zsh
# ---------------------------------------------------------------------------

test_monom_zsh_function_defined() {
  if ! command -v zsh > /dev/null 2>&1; then
    echo "SKIP: zsh not available"
    return
  fi

  local fn_defined
  fn_defined=$(zsh --no-rcs -c "
    source '$SRC_MONOM_ZSH'
    if [[ -n \"\${functions[_monom]}\" ]]; then echo yes; else echo no; fi
  " 2>/dev/null)

  assertEquals "_monom function should be defined in zsh" "yes" "$fn_defined"
}

# ---------------------------------------------------------------------------
# Namespace guard: old bare names and monomd must not exist after sourcing
# ---------------------------------------------------------------------------

# After sourcing src/monom in bash, verify that:
# 1. monom is available as a command/function.
# 2. The old bare names (pre-rename) are not defined as functions or variables.
# 3. monomd is not a defined function.
test_no_internals_in_monom_completion_namespace_bash() {
  # monom itself must be a function.
  local monom_fn
  monom_fn=$(bash --norc --noprofile -c "
    source '$SRC_MONOM'
    declare -f monom > /dev/null 2>&1 && echo yes || echo no
  " 2>/dev/null)
  assertEquals "monom function must be defined after sourcing" "yes" "$monom_fn"

  # Old bare env var names must not be set by sourcing (unset them first to
  # avoid inheriting values from a pre-existing shell session that may still
  # have the old names exported).
  local old_vars
  old_vars=$(bash --norc --noprofile -c "
    unset MONOM_BIN MONOM_LIB_ROOT MONOM_PROJECT_ROOT MONOM_USER_CONFIG
    source '$SRC_MONOM'
    for v in MONOM_BIN MONOM_LIB_ROOT MONOM_PROJECT_ROOT MONOM_USER_CONFIG; do
      if [ -n \"\${!v+x}\" ]; then echo \"\$v\"; fi
    done
  " 2>/dev/null)
  if [ -n "$old_vars" ]; then
    fail "old bare env vars set by sourcing: $old_vars"
  fi

  # Old bare function names must not be defined.
  local old_fns
  old_fns=$(bash --norc --noprofile -c "
    source '$SRC_MONOM'
    for fn in setup_monom monom_cfg monom_completion monomd; do
      if declare -f \"\$fn\" > /dev/null 2>&1; then echo \"\$fn\"; fi
    done
  " 2>/dev/null)
  if [ -n "$old_fns" ]; then
    fail "old bare function names still defined after sourcing: $old_fns"
  fi
}

# ---------------------------------------------------------------------------

# shellcheck disable=SC1090
. "$SHUNIT2"
