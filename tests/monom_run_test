# ---------------------------------------------------------------------------
# run hook: multi-token output must resolve, in both shells
# ---------------------------------------------------------------------------

test_bash_run_hook_expands_alias_to_multi_token() {
  local proj output
  proj=$(make_aliasing_project)
  output=$(run_monom_in bash "$proj" dbm)
  assert_output_contains_line "run hook 'dbm' -> 'db migrate' should run db/migrate in bash" \
    "$output" "ran db/migrate"
  rm -rf "$proj"
}

test_zsh_run_hook_expands_alias_to_multi_token() {
  if ! command -v zsh > /dev/null 2>&1; then
    echo "SKIP: zsh not available"
    return
  fi
  local proj output
  proj=$(make_aliasing_project)
  output=$(run_monom_in zsh "$proj" dbm)
  assert_output_contains_line "run hook 'dbm' -> 'db migrate' should run db/migrate in zsh" \
    "$output" "ran db/migrate"
  rm -rf "$proj"
