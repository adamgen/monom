# ---------------------------------------------------------------------------
# run hook failure: surface the author's error and abort (do NOT fall back)
# ---------------------------------------------------------------------------

test_bash_run_hook_failure_surfaces_error_and_aborts() {
  local proj output status
  proj=$(make_failing_hook_project)

  # run_monom_in merges stderr into stdout and runs in a command substitution,
  # so $? immediately after captures monom's exit status.
  output=$(run_monom_in bash "$proj" release)
  status=$?

  # The hook's own diagnostic must reach the user.
  assert_output_contains_line "hook stderr should be surfaced in bash" \
    "$output" "run hook: boom"
  # The fallback command must NOT have run.
  assert_output_lacks_line "monom must not fall back to running release in bash" \
    "$output" "ran release"
  # monom should exit with the hook's exit code.
  assertEquals "monom should exit with the hook's status in bash" "3" "$status"

  rm -rf "$proj"
}

test_zsh_run_hook_failure_surfaces_error_and_aborts() {
  if ! command -v zsh > /dev/null 2>&1; then
    echo "SKIP: zsh not available"
    return
  fi
  local proj output status
  proj=$(make_failing_hook_project)

  output=$(run_monom_in zsh "$proj" release)
  status=$?

  assert_output_contains_line "hook stderr should be surfaced in zsh" \
    "$output" "run hook: boom"
  assert_output_lacks_line "monom must not fall back to running release in zsh" \
    "$output" "ran release"
  assertEquals "monom should exit with the hook's status in zsh" "3" "$status"

  rm -rf "$proj"
}

# ---------------------------------------------------------------------------

# shellcheck disable=SC1090
. "$SHUNIT2"
