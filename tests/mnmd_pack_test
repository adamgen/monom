#!/bin/bash
# shUnit2 e2e tests for: mnmd pack
# Run directly: bash tests/mnmd_pack_test

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MONOMD="$REPO_ROOT/bin/mnmd"
SHUNIT2="$REPO_ROOT/dependencies/shunit2"

# shellcheck disable=SC1091
. "$SCRIPT_DIR/helpers"

# ---------------------------------------------------------------------------
# mnmd pack
# ---------------------------------------------------------------------------

test_pack_resolves_single_token_to_absolute_path() {
  tmp=$(make_tmp_project)
  make_cmd "$tmp/command1"
  result=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack command1)
  assertEquals "pack should resolve single token to absolute path" "$tmp/command1" "$result"
  rm -rf "$tmp"
}

test_pack_joins_multiple_tokens_with_slashes() {
  tmp=$(make_tmp_project)
  make_cmd "$tmp/category1/sub_command1"
  result=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack category1 sub_command1)
  assertEquals "pack should join tokens with slashes" "$tmp/category1/sub_command1" "$result"
  rm -rf "$tmp"
}

test_pack_exits_nonzero_when_resolved_file_does_not_exist() {
  tmp=$(make_tmp_project)
  err=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack command1 2>&1)
  assertNotEquals "pack must exit non-zero when resolved file does not exist" 0 $?
  assertContains "error must mention 'command not found'" "$err" "command not found"
  rm -rf "$tmp"
}

test_pack_exits_nonzero_when_resolved_file_is_not_executable() {
  tmp=$(make_tmp_project)
  cat > "$tmp/command1" <<'EOF'
#!/bin/sh
EOF
  # deliberately not chmod +x
  err=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack command1 2>&1)
  assertNotEquals "pack must exit non-zero when resolved file is not executable" 0 $?
  assertContains "error must mention 'not executable'" "$err" "not executable"
  rm -rf "$tmp"
}

test_pack_exits_nonzero_when_no_root_found() {
  tmp=$(mktemp -d)
  err=$( (cd "$tmp" && _MONOM_PROJECT_ROOT="" "$MONOMD" pack command1) 2>&1)
  assertNotEquals "pack must exit non-zero when no root found" 0 $?
  assertContains "error must mention 'monom project root'" "$err" "monom project root"
  rm -rf "$tmp"
}

# ---------------------------------------------------------------------------
# mnmd pack: command groups (directories) exit 3 as a pure signal.
# pack does NOT enumerate children — stdout and stderr are both empty. The
# child listing is the caller's job via the `complete` discovery hook.
# ---------------------------------------------------------------------------

test_pack_group_exits_3_with_empty_stdout() {
  tmp=$(make_tmp_project)
  make_cmd "$tmp/infra/cloud"
  make_cmd "$tmp/infra/local"
  out=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack infra 2>/dev/null)
  status=$?
  assertEquals "pack must exit 3 for a command group" 3 "$status"
  assertEquals "pack must not enumerate children on stdout" "" "$out"
  rm -rf "$tmp"
}

test_pack_group_writes_nothing_to_stderr() {
  tmp=$(make_tmp_project)
  make_cmd "$tmp/infra/cloud"
  err=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack infra 2>&1 1>/dev/null)
  assertEquals "pack group outcome must keep stderr empty" "" "$err"
  rm -rf "$tmp"
}

test_pack_nested_group_exits_3() {
  tmp=$(make_tmp_project)
  make_cmd "$tmp/infra/cloud/deploy"
  out=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack infra cloud 2>/dev/null)
  status=$?
  assertEquals "nested group must exit 3" 3 "$status"
  assertEquals "nested group prints nothing to stdout" "" "$out"
  rm -rf "$tmp"
}

test_pack_empty_group_exits_3_with_empty_stdout() {
  tmp=$(make_tmp_project)
  mkdir -p "$tmp/empty"
  out=$(_MONOM_PROJECT_ROOT="$tmp" "$MONOMD" pack empty 2>/dev/null)
  status=$?
  assertEquals "empty group must exit 3" 3 "$status"
  assertEquals "empty group prints nothing to stdout" "" "$out"
  rm -rf "$tmp"
}

# shellcheck disable=SC1090
. "$SHUNIT2"
