#!/bin/bash

# Get the directory where the test script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MONOM_SOURCE="$SCRIPT_DIR/monom_source"

# Set up test environment
setUp() {
    # Create a temporary test directory structure
    TEST_DIR=$(mktemp -d)
    
    # Create nested directories
    mkdir -p "$TEST_DIR/project"
    touch "$TEST_DIR/project/monom"
    touch "$TEST_DIR/project/run"
    chmod +x "$TEST_DIR/project/run"
    chmod +x "$TEST_DIR/project/monom"
    
    # Save original value of MONOM_PROJECT_ROOT
    OLD_MONOM_PROJECT_ROOT="$MONOM_PROJECT_ROOT"
    
    # Source the file to test
    # shellcheck source=./monom_source
    . "${MONOM_SOURCE}"
}

# Clean up after tests
tearDown() {
    cd "$SCRIPT_DIR" || exit  # Return to the script directory before cleanup
    rm -rf "$TEST_DIR"
    
    # Restore original MONOM_PROJECT_ROOT
    MONOM_PROJECT_ROOT="$OLD_MONOM_PROJECT_ROOT"
    unset OLD_MONOM_PROJECT_ROOT
}

# Test setup_monom with valid project root
test_setup_monom_with_valid_root() {
    MONOM_PROJECT_ROOT="$TEST_DIR/project"
    
    setup_monom
    status=$?
    
    assertEquals "setup_monom should return 0 with valid root" 0 "$status"
    assertEquals "MONOM_PROJECT_ROOT should be set correctly" \
        "$TEST_DIR/project" "$MONOM_PROJECT_ROOT"
}

# Test setup_monom with invalid project root
test_setup_monom_with_invalid_root() {
    MONOM_PROJECT_ROOT="/nonexistent/path"
    
    output=$(setup_monom 2>&1)
    status=$?
    
    assertNotEquals "setup_monom should return non-zero with invalid root" 0 "$status"
    assertEquals "Should show correct error message" \
        "No folder on path /nonexistent/path" "$output"
}

# Test setup_monom with unset project root
test_setup_monom_with_unset_root() {
    unset MONOM_PROJECT_ROOT
    mkdir -p "$TEST_DIR/project/a/b/c"
    touch "$TEST_DIR/project/monom"
    cd "$TEST_DIR/project/a/b/c" || exit
    setup_monom
    status=$?

    assertEquals "setup_monom find parent monom" 0 "$status"
}

# Test monom command
test_monom_command() {
    MONOM_PROJECT_ROOT="$TEST_DIR/project"
    
    # shellcheck disable=SC2119
    output=$(monom)
    status=$?
    
    GREEN='\033[0;32m'
    BLUE='\033[0;34m'
    NC='\033[0m' # No Color

    local test_failed=0
    
    if [ "$status" -ne 0 ]; then
        fail "monom command should return 0 but got $status"
        test_failed=1
    fi
    
    expected_output="$(log::success "Using monom from:" "$MONOM_PROJECT_ROOT")"
    if [ "$output" != "$expected_output" ]; then
        fail "monom command output mismatch:
Expected: $expected_output
Got:      $output"
        test_failed=1
    fi
    
    [ $test_failed -eq 0 ] || return 1
}

# Test monom command with invalid setup
test_monom_command_with_invalid_setup() {
    MONOM_PROJECT_ROOT="/nonexistent/path"
    
    # shellcheck disable=SC2119
    output=$(monom 2>&1)
    status=$?
    
    assertNotEquals "monom command should return non-zero with invalid setup" 0 "$status"
}

. "$MONOM_LIB_ROOT/sh_utils/log"
# shellcheck source=../dependencies/shunit2
. "../dependencies/shunit2"
