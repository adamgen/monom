#!/bin/bash

# Source logging utilities
# shellcheck source=sh_utils/log
. "$MONOM_LIB_ROOT/sh_utils/log"

if [ ! -x "$MONOM_CONFIG_FILE" ]; then
    log::error "Error:" "Command file \"$MONOM_CONFIG_FILE\" does not have execute permissions"
    exit 1
fi

log::success "Using monom from:" "$MONOM_PROJECT_ROOT"
# shellcheck disable=SC2206
command_chain="$*"

if [ -z "$*" ]; then
    # todo add echo available commands
    exit 0
fi

relative_run_path=$(echo "$@" | "$MONOM_CONFIG_FILE" run)
run_path="$MONOM_PROJECT_ROOT/$relative_run_path"

# all_args=($@)
# input_length=${#all_args[@]}
# last_index=$((input_length-1))
# last_element="${all_args[$last_index]}"

# echo
# echo
# log::info "last element" "$last_element"
# log::info "command_chain" "$command_chain"
# echo
# echo

if [ -f "$run_path" ]; then
    # Extract shebang from the first line
    shebang=$(head -n 1 "$run_path")
    
    if [[ "$shebang" =~ ^#! ]]; then
        # Extract interpreter from shebang (remove #! prefix)
        interpreter="${shebang#\#!}"
        # Remove any leading/trailing whitespace
        interpreter=$(echo "$interpreter" | xargs)
        
        # Check if interpreter exists and is executable
        if command -v "$(echo "$interpreter" | cut -d' ' -f1)" >/dev/null 2>&1; then
            $interpreter "$run_path"
        else
            log::error "Error:" "Interpreter \"$interpreter\" not found or not executable"
            exit 1
        fi
    else
        # No shebang found, check if file has execute permissions and run directly
        if [ ! -x "$run_path" ]; then
            log::error "Error:" "Command file \"$run_path\" does not have execute permissions and no shebang found"
            exit 1
        fi
        $run_path
    fi
else
    log::error "Error:" "Command not found: \"$command_chain\" on run \"$run_path\""
    exit 1
fi
